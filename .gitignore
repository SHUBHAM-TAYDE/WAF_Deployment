# =============================================================================
# CyberSentinel WAF — .gitignore
# =============================================================================

# =============================================================================
# SECRETS & CREDENTIALS  ← NEVER commit these
# =============================================================================
.env
.env.*
*.env
jwt_secret.txt
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
credentials/

# =============================================================================
# SENSITIVE RUNTIME CONFIG  ← Contains bcrypt password hashes + live WAF rules
# =============================================================================
backend/app/config/settings.json
backend/app/config/rule_states.json
backend/app/config/false_positives.db

# =============================================================================
# DATABASES  ← Live traffic data, ML events, user data — never commit
# =============================================================================
*.db
*.sqlite
*.sqlite3
backend/app.db
backend/waf_dashboard.db
backend/waf_gui.db
backend/app/data/ml_events.db
ml-waf/ml_events.db

# =============================================================================
# GEOLOCATION DATABASE  ← Large binary, licensed — download separately
# =============================================================================
backend/app/data/GeoLite2-Country.mmdb
*.mmdb

# =============================================================================
# ML MODEL BINARIES  ← Large binary blobs, retrained automatically
# =============================================================================
ml-waf/models/backups/
*.pkl
*.joblib
*.h5
*.onnx
*.pt
*.pth

# =============================================================================
# PYTHON VIRTUAL ENVIRONMENTS
# =============================================================================
venv/
.venv/
env/
.env/
backend/venv/
ml-waf/venv/
*.egg-info/
dist/
build/
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
pip-log.txt
pip-delete-this-directory.txt

# =============================================================================
# NODE / FRONTEND BUILD ARTIFACTS
# =============================================================================
node_modules/
dist/
dist-ssr/
*.local
.cache/
.parcel-cache/
.next/
out/

# =============================================================================
# LOGS  ← Runtime log files, never commit
# =============================================================================
*.log
logs/
ml-waf/logs/
backend/test_logs/
vite.log
waf_ddos.txt

# =============================================================================
# TEST / DEBUG / SCRATCH SCRIPTS  ← One-off dev scripts
# =============================================================================
read_db.py
rewrite_settings.py
dummy_app.py
test_analytics.py
test_ddos_parser.py
backend/test_discovery.py
backend/test_put.py
backend/test_update.py
ml-waf/generate_dummy_models.py
ml-waf/test_pipeline.py

# =============================================================================
# DOCUMENTATION DRAFTS / BLUEPRINTS (internal notes)
# =============================================================================
ml_waf_blueprint.md

# =============================================================================
# OS / EDITOR NOISE
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# IDE
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~

# =============================================================================
# COMPILED / BINARY ARTIFACTS
# =============================================================================
*.so
*.dylib
*.dll
*.class
*.o
*.a

# =============================================================================
# PACKAGE MANAGER LOCKS (optional — keep package-lock.json for reproducibility)
# =============================================================================
# package-lock.json   ← intentionally NOT ignored (good for reproducibility)
# requirements.txt    ← intentionally NOT ignored

# =============================================================================
# WHAT IS INTENTIONALLY TRACKED (DO NOT ADD THESE ABOVE)
# =============================================================================
# src/                   ← all React frontend source
# backend/app/           ← all Python backend source (except config/settings.json)
# backend/requirements.txt
# ml-waf/*.py            ← all ML training + inference code
# ml-waf/requirements.txt
# scripts/               ← all deployment and automation shell scripts
# public/                ← static frontend assets
# package.json
# vite.config.js
# README.md
# backend/app/config/settings.py  ← code only, no secrets
